# Telegram bot token from @BotFather
BOT_TOKEN=

# Server timezone — must match the family's local time
# Example: Europe/Kyiv, Europe/Warsaw, America/New_York
TZ=Europe/Warsaw

# IMPORTANT: add the bot to your family group and grant it admin rights
# Required permissions: Delete messages, Pin messages

# Set to "production" to disable /dev_* commands
NODE_ENV=development

# Path to the folder where the bot will store its data (SQLite database, logs, etc.)
# Example: ./data for Windows, /DATA/AppData/chorecop for Linux
DATA_PATH=/DATA/AppData/chorecop
